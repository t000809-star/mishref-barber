# Copy to .env.development.local (dev Supabase project) and
# .env.production.local (prod Supabase project). Vite picks the right
# file based on mode: `npm run dev` reads .env.development.local;
# `npm run build` reads .env.production.local. Both are gitignored.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
